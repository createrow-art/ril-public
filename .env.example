# Absolute path to a folder where your articles will be saved as Markdown files.
# The service creates Inbox/, Saved/, Archive/ inside it on first run.
# Does NOT require Obsidian — any folder works.
VAULT_PATH=/Users/yourname/Documents/RIL

# Anthropic API key — used for LLM auto-tagging and Smart Mode.
# Get a key at https://console.anthropic.com
# Optional: works without it, but tagging and Smart Mode will be disabled.
ANTHROPIC_API_KEY=your-anthropic-api-key
