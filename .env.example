# Discord bot (for URL ingestion via Discord channel)
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-server-id
DISCORD_CHANNEL_ID=your-channel-id

# Absolute path to your Obsidian vault root
# The service creates Inbox/, Saved/, Archive/ inside it on first run
VAULT_PATH=/Users/yourname/Documents/RIL

# Moonshot/Kimi API — used for LLM tagging + Smart Mode
# Get a key at https://platform.moonshot.cn
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
