{
  "manifest_version": 3,
  "name": "RIL — Read It Later",
  "version": "1.0.0",
  "description": "Triage your read-it-later inbox on every new tab.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "contextMenus"],
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}
